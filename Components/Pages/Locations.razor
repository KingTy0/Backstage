@page "/Locations"
@using Microsoft.EntityFrameworkCore
@using QG = Microsoft.AspNetCore.Components.QuickGrid
@using Microsoft.AspNetCore.Components.QuickGrid
@using PuppetFestAPP.Web.Data
@using System.Linq
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Locations</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Locations Management</MudText>

<MudButton Color="Color.Primary" Variant="Variant.Filled" href="/Locations/create" Class="mb-4">
    Create New Location
</MudButton>

@if (AllLocations == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <div class="mb-4">
        <MudTextField @bind-Value="searchTerm" 
                      Placeholder="Search by name..." 
                      Adornment="Adornment.Start" 
                      AdornmentIcon="@Icons.Material.Filled.Search" 
                      Immediate="true" />
    </div>

    <Microsoft.AspNetCore.Components.QuickGrid.QuickGrid Items="@FilteredLocations.AsQueryable()" Pagination="pagination">
    <Microsoft.AspNetCore.Components.QuickGrid.PropertyColumn Property="@(l => l.Name)" Sortable="true" Title="Name" />
    <Microsoft.AspNetCore.Components.QuickGrid.PropertyColumn Property="@(l => l.Address)" Sortable="true" Title="Address" />
    
    <Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn Title="Type">
        @{
            var loc = context as Location;
            if (loc != null)
            {
                <MudChip T="string" Color="@(loc.Type == LocationType.Van ? Color.Warning : Color.Info)">
                    @loc.Type
                </MudChip>
            }
        }
    </Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn>

    <Microsoft.AspNetCore.Components.QuickGrid.PropertyColumn Property="@(l => l.IsActive)" Title="Active" />

    <Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn Title="Actions">
        @{
            var loc = context as Location;
            if (loc != null)
            {
                <MudStack Row="true">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" href="@($"/locations/edit/{loc.Id}")">Edit</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" href="@($"/locations/delete/{loc.Id}")">Delete</MudButton>
                </MudStack>
            }
        }
    </Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn>
</Microsoft.AspNetCore.Components.QuickGrid.QuickGrid>

<Microsoft.AspNetCore.Components.QuickGrid.Paginator State="pagination" />

}

@code {
    // Renamed to AllLocations to avoid conflict with the Page name "Locations"
    private List<Location>? AllLocations;
    private string searchTerm = "";

    private IEnumerable<Location> FilteredLocations => 
        string.IsNullOrWhiteSpace(searchTerm) 
            ? AllLocations ?? Enumerable.Empty<Location>() 
            : (AllLocations ?? Enumerable.Empty<Location>())
                .Where(l => l.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    QG.PaginationState pagination = new() { ItemsPerPage = 20 };

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        AllLocations = await db.Locations.ToListAsync();
    }
}
