@page "/Locations"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using PuppetFestAPP.Web.Data
@using System.Linq
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Locations</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Locations Management</MudText>

<MudButton Color="Color.Primary" Variant="Variant.Filled" href="/Locations/create" Class="mb-4">
    Create New Location
</MudButton>

@if (Locations == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <div class="mb-4">
        <MudTextField @bind-Value="searchTerm" 
                      Placeholder="Search by name..." 
                      Adornment="Adornment.Start" 
                      AdornmentIcon="@Icons.Material.Filled.Search" 
                      Immediate="true" />
    </div>

    <QuickGrid Items="@FilteredLocations.AsQueryable()" Pagination="pagination">
        <PropertyColumn Property="@(l => l.Name)" Sortable="true" Title="Name" />
        <PropertyColumn Property="@(l => l.Address)" Sortable="true" Title="Address" />
        
        <TemplateColumn Title="Type" Context="loc">
            <MudChip T="string" Color="@(loc.Type == LocationType.Van ? Color.Warning : Color.Info)">
                @loc.Type
            </MudChip>
        </TemplateColumn>

        <PropertyColumn Property="@(l => l.IsActive)" Title="Active" />

        <TemplateColumn Title="Actions" Context="loc">
            <MudStack Row="true">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" href="@($"/locations/edit/{loc.Id}")">Edit</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small" href="@($"/locations/delete/{loc.Id}")">Delete</MudButton>
            </MudStack>
        </TemplateColumn>
    </QuickGrid>

    <Paginator State="pagination" />
}

@code {
    private List<Location>? Locations;
    private string searchTerm = "";

    private IEnumerable<Location> FilteredLocations => 
        string.IsNullOrWhiteSpace(searchTerm) 
            ? Locations ?? Enumerable.Empty<Location>() 
            : (Locations ?? Enumerable.Empty<Location>())
                .Where(l => l.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    PaginationState pagination = new() { ItemsPerPage = 20 };

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Locations = await context.Locations.ToListAsync();
    }
}
