@page "/products/edit/{id:int}"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Edit Product</PageTitle>

<div class="container">
    <h1>Edit Product</h1>
    <hr />

    @if (Form is null)
    {
        <div class="alert alert-info">Loading product data...</div>
    }
    else
    {
        <EditForm method="post" Model="Form" OnValidSubmit="UpdateProduct" FormName="editProduct">
            <DataAnnotationsValidator />
            <ValidationSummary class="mud-text-error" />

            <div class="mb-3">
                <label class="form-label">Name:</label>
                <MudTextField @bind-Value="Form.Name"  />
                <ValidationMessage For="() => Form.Name" class="mud-text-error" />
            </div>

            <div class="mb-3">
                <label class="form-label">Price:</label>
                <MudNumericField @bind-Value="Form.Price"  />
                <ValidationMessage For="() => Form.Price" class="mud-text-error" />
            </div>

            @* --- SIZE DROPDOWN --- *@
            <div class="mb-3">
                <label class="form-label">Size:</label>
                <InputSelect @bind-Value="Form.Size" >
                    <option value="">-- Select Size --</option>
                    @foreach (var size in Enum.GetValues<ProductSize>())
                    {
                        <option value="@size">@size</option>
                    }
                </InputSelect>
            </div>

            @* --- COLOR DROPDOWN --- *@
            <div class="mb-3">
                <label class="form-label">Color:</label>
                <InputSelect @bind-Value="Form.Color" >
                    <option value="">-- Select Color --</option>
                    @foreach (var color in Enum.GetValues<ProductColor>())
                    {
                        <option value="@color">@color</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Category:</label>
                <InputSelect @bind-Value="Form.CategoryId" >
                    @foreach (var cat in Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Description:</label>
                <MudTextField TextArea="true" Lines="3" @bind-Value="Form.Description" /> 
            </div>

            <div class="mt-4">
                <MudButton Type="Submit" Variant="Variant.Filled" Color="Color.Success" >Save Changes</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/products">Cancel</MudButton>
            </div>
        </EditForm>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    [SupplyParameterFromForm]
    private ProductFormModel? Form { get; set; }

    private List<Category> Categories = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Categories = await context.Categories.ToListAsync();

        if (Form is null)
        {
            var product = await context.Products.FindAsync(Id);
            
            if (product is null)
            {
                NavigationManager.NavigateTo("/products");
                return;
            }

            Form = new ProductFormModel
            {
                Name = product.Name,
                Price = product.Price,
                CategoryId = product.CategoryId,
                Description = product.Description,
                ParentProductId = product.ParentProductId,
                Size = product.Size,
                Color = product.Color
            };
        }
    }

    private async Task UpdateProduct()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var product = await context.Products.FindAsync(Id);

        if (product is not null && Form is not null)
        {
            product.Name = Form.Name;
            product.Price = Form.Price;
            product.CategoryId = Form.CategoryId;
            product.Description = Form.Description ?? "";
            product.Size = Form.Size;
            product.Color = Form.Color;

            try
            {
                await context.SaveChangesAsync();
            
                if (product.ParentProductId.HasValue)
                {
                    NavigationManager.NavigateTo($"/products/details/{product.ParentProductId}");
                }
                else
                {
                    NavigationManager.NavigateTo("/products");
                }
            }
            // This 'when' clause is the magic filter
            catch (Exception ex) when (ex is not Microsoft.AspNetCore.Components.NavigationException)
            {
                Console.WriteLine($"Actual error updating product: {ex.Message}");
            }
        }
    }
}