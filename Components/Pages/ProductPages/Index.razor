@page "/Products"
@using Microsoft.EntityFrameworkCore
@using QG = Microsoft.AspNetCore.Components.QuickGrid
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Product Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudStack Direction="Row" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h4">Product Management</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" href="Products/create">
            Create New Master Product
        </MudButton>
    </MudStack>

    <div class="mb-6">
        <MudTextField @bind-Value="searchTerm" 
                      Placeholder="Search by product name..." 
                      Adornment="Adornment.Start" 
                      AdornmentIcon="@Icons.Material.Filled.Search" 
                      Immediate="true" 
                      Variant="Variant.Outlined" />
    </div>

    <MudPaper Elevation="1" Class="pa-4">
        <QG.QuickGrid Items="FilteredProducts" Pagination="pagination">
            @* Image Column *@
            <QG.TemplateColumn Title="Image" Context="prod">
                @if (prod.Image != null && !string.IsNullOrEmpty(prod.Image.FileName))
                {
                    <img class="rounded shadow-sm" src="/Images/Products/@prod.Image.FileName" 
                         style="width: 50px; height: 50px; object-fit: cover;"/>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">No Image</MudText>
                }
            </QG.TemplateColumn>

            <QG.PropertyColumn Property="@(p => p.Name)" Sortable="true" Title="Product Name" />
            
            <QG.TemplateColumn Title="Category" Sortable="true" Context="prod">
                @prod.Category?.Name
            </QG.TemplateColumn>

            <QG.PropertyColumn Property="@(p => p.Price)" Format="C" Sortable="true" Title="Price" />

            <QG.TemplateColumn Title="Actions" Context="prod">
                <MudStack Row="true" Spacing="1">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" 
                               href="@($"/products/edit/{prod.Id}")">Edit</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Info" 
                               href="@($"/products/details/{prod.Id}")">Manage</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error" 
                               href="@($"/products/delete/{prod.Id}")">Delete</MudButton>
                </MudStack>
            </QG.TemplateColumn>
        </QG.QuickGrid>

        <div class="mt-4">
            <QG.Paginator State="pagination" />
        </div>
    </MudPaper>
</MudContainer>

@code {
    private IQueryable<Product>? Products;
    private string searchTerm = "";

    private IQueryable<Product> FilteredProducts => 
        string.IsNullOrWhiteSpace(searchTerm) 
            ? Products ?? Enumerable.Empty<Product>().AsQueryable() 
            : (Products ?? Enumerable.Empty<Product>().AsQueryable())
                .Where(p => p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    QG.PaginationState pagination = new QG.PaginationState { ItemsPerPage = 20 };

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var data = await context.Products
            .Include(p => p.Category)
            .Include(p => p.Image)
            .Where(p => p.ParentProductId == null)
            .ToListAsync();
            
        Products = data.AsQueryable();
    }
}
