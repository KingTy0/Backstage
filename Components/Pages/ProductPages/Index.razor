@page "/Products"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Product Management</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h4">Product Management</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" href="Products/create">
            Create New Master Product
        </MudButton>
    </MudStack>

    <div class="mb-6">
        <MudTextField @bind-Value="searchTerm" 
                      Placeholder="Search by product name..." 
                      Adornment="Adornment.Start" 
                      AdornmentIcon="@Icons.Material.Filled.Search" 
                      Immediate="true" 
                      Variant="Variant.Outlined" />
    </div>

    <MudPaper Elevation="1" Class="pa-4">
        @* Using FULL NAMESPACE to bypass the alias bug and fix 'prod' scope errors *@
        <Microsoft.AspNetCore.Components.QuickGrid.QuickGrid Items="FilteredProducts" Pagination="pagination">
            
          <Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn Title="Image" Context="prod">
    @if (prod.Image != null && !string.IsNullOrEmpty(prod.Image.FileName))
    {
        <img class="rounded shadow-sm" 
             src="/images/products/@prod.Image.FileName" 
             style="width: 50px; height: 50px; object-fit: cover;" 
             alt="@prod.Name" />
    }
    else
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary">No Image</MudText>
    }
</Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn>

            <Microsoft.AspNetCore.Components.QuickGrid.PropertyColumn Property="@(p => p.Name)" Sortable="true" Title="Product Name" />
            
            <Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn Title="Category" Sortable="true" Context="prod">
                @prod.Category?.Name
            </Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn>

            <Microsoft.AspNetCore.Components.QuickGrid.PropertyColumn Property="@(p => p.Price)" Format="C" Sortable="true" Title="Price" />

            <Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn Title="Actions" Context="prod">
                <MudStack Row="true" Spacing="1">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" 
                               href="@($"/products/edit/{prod.Id}")">Edit</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Info" 
                               href="@($"/products/details/{prod.Id}")">Manage</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error" 
                               href="@($"/products/delete/{prod.Id}")">Delete</MudButton>
                </MudStack>
            </Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn>

        </Microsoft.AspNetCore.Components.QuickGrid.QuickGrid>

        <div class="mt-4">
            <Microsoft.AspNetCore.Components.QuickGrid.Paginator State="pagination" />
        </div>
    </MudPaper>
</MudContainer>

@code {
    private IQueryable<Product>? Products;
    private string searchTerm = "";

    private IQueryable<Product> FilteredProducts => 
        string.IsNullOrWhiteSpace(searchTerm) 
            ? Products ?? Enumerable.Empty<Product>().AsQueryable() 
            : (Products ?? Enumerable.Empty<Product>().AsQueryable())
                .Where(p => p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    Microsoft.AspNetCore.Components.QuickGrid.PaginationState pagination = new() { ItemsPerPage = 20 };

   protected override async Task OnInitializedAsync()
    {
        // 1. Open the connection
        using var db = await DbFactory.CreateDbContextAsync();

        // 2. Fetch the data into a List (This fixes the 'No Image' by using Include)
        var data = await db.Products
            .Include(p => p.Category)
            .Include(p => p.Image)
            .Where(p => p.ParentProductId == null)
            .ToListAsync();
            
        // 3. Convert that list back to IQueryable so QuickGrid and FilteredProducts are happy
        Products = data.AsQueryable();
    }
}
