@page "/products/create"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment

<PageTitle>Create Product</PageTitle>

<div class="container mt-4">
    <h1>Create @(parentId.HasValue ? "Variant" : "New Product")</h1>
    <hr />

    <EditForm Model="Form" OnValidSubmit="AddProduct" FormName="createProduct" >
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />
        
        <input type="hidden" @bind="Form.ParentProductId" />
        <InputText @bind-Value="uploadedFileName" style="display:none"/>

        <div class="mb-3">
            <label class="form-label">Name</label>
            <InputText @bind-Value="Form.Name" class="form-control" />
            <ValidationMessage For="() => Form.Name" class="text-danger" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Price</label>
                <InputNumber @bind-Value="Form.Price" class="form-control" />
                <ValidationMessage For="() => Form.Price" class="text-danger" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Category</label>
                <InputSelect @bind-Value="Form.CategoryId" class="form-control">
                    <option value="0">-- Select Category --</option>
                    @foreach (var cat in Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </InputSelect>
            </div>
        </div>

       <div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label">Size (Optional)</label>
        @* Change from <select @bind> to <InputSelect @bind-Value> *@
        <InputSelect @bind-Value="Form.Size" class="form-control">
            @foreach (var size in Enum.GetValues<ProductSize>())
            {
                <option value="@size">@size</option>
            }
        </InputSelect>
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label">Color (Optional)</label>
        @* Change from <select @bind> to <InputSelect @bind-Value> *@
        <InputSelect @bind-Value="Form.Color" class="form-control">
            @foreach (var color in Enum.GetValues<ProductColor>())
            {
                <option value="@color">@color</option>
            }
        </InputSelect>
    </div>
</div>

        <div class="mb-3">
            <label class="form-label">Product Image</label>
            <InputFile OnChange="LoadFiles" class="form-control" />
            @if (!string.IsNullOrEmpty(uploadedFileName))
            {
                <div class="mt-2">
                    <img src="/images/products/@uploadedFileName" style="height:100px; width:auto; border-radius:8px;" />
                    <p class="text-success">Image uploaded successfully!</p>
                </div>
            }
            @if (isUploading) { <p class="text-info">Uploading...</p> }
        </div>

        <button type="submit" class="btn btn-primary" disabled="@isUploading">Save Product</button>
        <a href="/products" class="btn btn-secondary">Cancel</a>
    </EditForm>
</div>

@code {
    [SupplyParameterFromForm]
    public ProductFormModel Form { get; set; } = new();

    [SupplyParameterFromQuery]
    public int? parentId { get; set; }

    private List<Category> Categories = new();
    private bool isUploading = false;
    private string? uploadedFileName;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Categories = await context.Categories.ToListAsync();

        if (parentId.HasValue && string.IsNullOrEmpty(Form.Name))
        {
            var parent = await context.Products.FindAsync(parentId.Value);
            if (parent != null)
            {
                Form.ParentProductId = parent.Id;
                Form.Name = parent.Name;
                Form.CategoryId = parent.CategoryId;
                Form.Price = parent.Price;
            }
        }
    }

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            isUploading = true;
            // Generate name once
            var newName = Guid.NewGuid().ToString() + Path.GetExtension(file.Name);
            
            // LOCK IT INTO THE FORM IMMEDIATELY
            Form.ImageFileName = newName;
            uploadedFileName = newName; 

            var path = Path.Combine(Environment.WebRootPath, "images", "products", newName);
            Directory.CreateDirectory(Path.GetDirectoryName(path)!);

            await using FileStream fs = new(path, FileMode.Create);
            await file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 10).CopyToAsync(fs);
            
            isUploading = false;
            StateHasChanged();
        }
    }

   private async Task AddProduct()
{
    if (Form.CategoryId == 0) return;

    using var context = await DbFactory.CreateDbContextAsync();
    int? finalImageId = null;

    var fileNameToUse = Form.ImageFileName ?? uploadedFileName;

    // Use the local variable that is now 'synced' by the hidden InputText
    if (!string.IsNullOrEmpty(uploadedFileName))
    {
        var newImg = new PuppetFestAPP.Web.Models.Image 
        { 
            FileName = uploadedFileName,
            AltText = Form.Name 
        };
        
        context.Images.Add(newImg); 
        await context.SaveChangesAsync(); 
        finalImageId = newImg.Id; 
    }

    var newProduct = new Product
    {
        Name = Form.Name,
        Price = Form.Price,
        CategoryId = Form.CategoryId,
        ParentProductId = Form.ParentProductId ?? parentId, 
        Size = Form.Size ?? ProductSize.NA,
        Color = Form.Color ?? ProductColor.NA,
        DateAdded = DateTime.Now,
        IsActive = true,
        Description = Form.Description ?? "",
        ImageId = finalImageId 
    };

    context.Products.Add(newProduct);
    await context.SaveChangesAsync();
    
    NavigationManager.NavigateTo("/products");
}
}