@page "/products/create"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using PuppetFestAPP.Web.Models
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment Environment

<PageTitle>Create Product</PageTitle>

<div class="container mt-4">
    <h1>Create @(parentId.HasValue ? "Variant" : "New Product")</h1>
    <hr />

    <EditForm Model="Form" OnValidSubmit="AddProduct" FormName="createProduct" Enhance>
        <DataAnnotationsValidator />
        <ValidationSummary class="mud-text-error" />
        
        <input type="hidden" @bind="Form.ParentProductId" />

        <div class="mb-3">
            <label class="form-label">Name</label>
            <MudTextField @bind-Value="Form.Name"  />
            <ValidationMessage For="() => Form.Name" class="mud-text-error" />
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Price</label>
                <MudNumericField @bind-Value="Form.Price"  />
                <ValidationMessage For="() => Form.Price" class="mud-text-error" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Category</label>
                <InputSelect @bind-Value="Form.CategoryId" >
                    <option value="0">-- Select Category --</option>
                    @foreach (var cat in Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </InputSelect>
            </div>
        </div>

       <div class="row">
    <div class="col-md-6 mb-3">
        <label class="form-label">Size (Optional)</label>
        @* Change from <select @bind> to <InputSelect @bind-Value> *@
        <InputSelect @bind-Value="Form.Size" >
            @foreach (var size in Enum.GetValues<ProductSize>())
            {
                <option value="@size">@size</option>
            }
        </InputSelect>
    </div>
    <div class="col-md-6 mb-3">
        <label class="form-label">Color (Optional)</label>
        @* Change from <select @bind> to <InputSelect @bind-Value> *@
        <InputSelect @bind-Value="Form.Color" >
            @foreach (var color in Enum.GetValues<ProductColor>())
            {
                <option value="@color">@color</option>
            }
        </InputSelect>
    </div>
</div>

        <div class="mb-3">
            <label class="form-label">Product Image</label>
            <InputFile OnChange="LoadFiles"  />
            @if (isUploading) { <p class="text-info">Uploading...</p> }
        </div>

        <MudButton Type="Submit" Variant="Variant.Filled" Color="Color.Primary"   disabled="@isUploading">Save Product</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Href="/products">Cancel</MudButton>
    </EditForm>
</div>

@code {
    [SupplyParameterFromForm]
    public ProductFormModel Form { get; set; } = new();

    [SupplyParameterFromQuery]
    public int? parentId { get; set; }

    private List<Category> Categories = new();
    private bool isUploading = false;
    private string? uploadedFileName;

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        Categories = await context.Categories.ToListAsync();

        if (parentId.HasValue && string.IsNullOrEmpty(Form.Name))
        {
            var parent = await context.Products.FindAsync(parentId.Value);
            if (parent != null)
            {
                Form.ParentProductId = parent.Id;
                Form.Name = parent.Name;
                Form.CategoryId = parent.CategoryId;
                Form.Price = parent.Price;
            }
        }
    }

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        isUploading = true;
        var file = e.File;
        if (file != null)
        {
            // Set a unique name to avoid overwriting
            uploadedFileName = Guid.NewGuid().ToString() + Path.GetExtension(file.Name);
            var path = Path.Combine(Environment.WebRootPath, "images", "products", uploadedFileName);

            // Create directory if it doesn't exist
            Directory.CreateDirectory(Path.GetDirectoryName(path)!);

            await using FileStream fs = new(path, FileMode.Create);
            await file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 10).CopyToAsync(fs);
        }
        isUploading = false;
    }

    private async Task AddProduct()
    {
        if (Form.CategoryId == 0) return;

        using var context = await DbFactory.CreateDbContextAsync();

        var newProduct = new Product
        {
            Name = Form.Name,
            Price = Form.Price,
            CategoryId = Form.CategoryId,
            ParentProductId = Form.ParentProductId ?? parentId, 
            Size = Form.Size ?? ProductSize.NA,
            Color = Form.Color ?? ProductColor.NA,
            DateAdded = DateTime.Now,
            IsActive = true,
            Description = Form.Description ?? "",
            // If we uploaded an image, we'd save the ID here
            // For now, let's just make sure the variant links
        };

        context.Products.Add(newProduct);
        await context.SaveChangesAsync();
        
        NavigationManager.NavigateTo(newProduct.ParentProductId.HasValue 
            ? $"/products/details/{newProduct.ParentProductId}" 
            : "/products");
    }
}