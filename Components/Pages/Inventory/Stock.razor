@page "/inventory/stock"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using PuppetFestAPP.Web.Data
@using System.Linq
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Stock Levels</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Stock Levels</MudText>

@if (StockData?.Any() == true)
{
    @foreach (var locGroup in StockData.GroupBy(x => x.Location))
    {
        <MudPaper Elevation="2" Class="mb-6">
            <MudToolBar>
                <MudText Typo="Typo.h6">
                    @locGroup.Key.Name (@locGroup.Key.Type) - Total: @locGroup.Sum(x => x.Quantity)
                </MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.Edit"
                           href="@($"/inventory/adjust/{locGroup.Key.Id}")">
                    End of Day Adjustment
                </MudButton>
            </MudToolBar>

            <div class="pa-4">
                <QuickGrid Items="@locGroup.AsQueryable()" TGridItem="ProductLocation">
                    <TemplateColumn Title="Product" Context="item">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.body1">@item.Product.Name</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @if (item.Product.Size != ProductSize.NA) { <span>Size: @item.Product.Size </span> }
                                @if (item.Product.Color != ProductColor.NA) { <span>| Color: @item.Product.Color</span> }
                            </MudText>
                        </div>
                    </TemplateColumn>
                    <PropertyColumn Property="@(x => x.Quantity)" Title="Qty" Sortable="true" />
                </QuickGrid>
            </div>
        </MudPaper>
    }
}
else
{
    <MudAlert Severity="Severity.Info">No stock records yet. Create some transfers to populate inventory!</MudAlert>
}

@code {
    private List<ProductLocation> StockData = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        StockData = await context.ProductLocations
            .Include(pl => pl.Product)
            .Include(pl => pl.Location)
            .Where(pl => pl.Quantity > 0)
            .OrderBy(pl => pl.Location.Name)
            .ThenBy(pl => pl.Product.Name)
            .ToListAsync();
    }
}
