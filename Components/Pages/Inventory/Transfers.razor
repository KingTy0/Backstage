@page "/inventory/transfers"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@using System.Linq
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Transfer History</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudStack Direction="Row" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h4">Transfer Boxes</MudText>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" href="/inventory/transfer/create">
            + New Transfer
        </MudButton>
    </MudStack>

    @if (TransferBoxes?.Any() == true)
    {
        <MudPaper Elevation="1" Class="pa-4">
            @* Using the full namespace to avoid component and context variable conflicts *@
            <Microsoft.AspNetCore.Components.QuickGrid.QuickGrid Items="@TransferBoxes.AsQueryable()" Pagination="pagination" TGridItem="StockTransferBox">
                
                <Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn Title="Date" Context="box">
                    @box.CreatedAt.ToString("MMM dd, yyyy")
                </Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn>

                <Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn Title="From → To" Context="box">
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@box.FromLocation?.Name</MudChip>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Class="mx-1" />
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@box.ToLocation?.Name</MudChip>
                </Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn>

                <Microsoft.AspNetCore.Components.QuickGrid.PropertyColumn Property="@(x => x.Items.Count)" Title="# Items" />

                <Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn Title="Items" Context="box">
                    @{
                        var items = box.Items ?? new List<StockTransferBoxItem>();
                        var itemPreview = string.Join(", ", items.Take(2).Select(i => $"{i.Product?.Name} x{i.Quantity}"));
                    }
                    <MudText Typo="Typo.body2">
                        @itemPreview
                        @if (items.Count > 2)
                        {
                            <span class="mud-text-secondary ml-1">(+@(items.Count - 2) more)</span>
                        }
                    </MudText>
                </Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn>

                <Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn Title="Actions" Context="box">
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Primary" 
                               Size="Size.Small" 
                               Href="@($"/inventory/transfer/details/{box.Id}")">
                        View
                    </MudButton>
                </Microsoft.AspNetCore.Components.QuickGrid.TemplateColumn>

            </Microsoft.AspNetCore.Components.QuickGrid.QuickGrid>

            <div class="mt-4">
                <Microsoft.AspNetCore.Components.QuickGrid.Paginator State="pagination" />
            </div>
        </MudPaper>
    }
    else
    {
        <MudAlert Severity="Severity.Info">
            No transfers yet. <MudLink href="/inventory/transfer/create">Create one</MudLink>
        </MudAlert>
    }
</MudContainer>

@code {
    private List<StockTransferBox> TransferBoxes = new();
    
    // Explicitly using the full type for the pagination state
    Microsoft.AspNetCore.Components.QuickGrid.PaginationState pagination = new() { ItemsPerPage = 20 };

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        TransferBoxes = await db.StockTransferBoxes
            .Include(b => b.FromLocation)
            .Include(b => b.ToLocation)
            .Include(b => b.Items).ThenInclude(i => i.Product)
            .OrderByDescending(b => b.CreatedAt)
            .ToListAsync();
    }
}
