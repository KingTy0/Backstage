@page "/"

<PageTitle>Puppet Fest Merch</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-16 text-center">
    <AuthorizeView>
        @* ── Content for logged-in users ── *@
        <Authorized>
            @* FIX: Use @context.User instead of @User *@
            <MudText Typo="Typo.h3" GutterBottom="true">Welcome back, @context.User.Identity?.Name!</MudText>
            <MudText Typo="Typo.body1">You are logged in.</MudText>
            <MudButton Variant="Variant.Text" Color="Color.Primary" href="/dashboard" Class="mt-4">
                Go to Dashboard →
            </MudButton>
        </Authorized>

        @* ── Content for anonymous visitors ── *@
        <NotAuthorized>
            <MudText Typo="Typo.h2" GutterBottom="true">Puppet Festival Merchandise</MudText>
            <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mb-8">
                Welcome to the Chicago Puppet Festival merchandise management system.
            </MudText>
            
            <MudStack Row="true" Justify="Justify.Center" Spacing="4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" href="Account/Login">
                    Login
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Large" href="Account/Register">
                    Register
                </MudButton>
            </MudStack>
        </NotAuthorized>
    </AuthorizeView>
</MudContainer>
