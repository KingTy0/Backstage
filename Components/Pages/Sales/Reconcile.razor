@page "/sales/reconcile/{LocationId:int}"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Daily Sales Reconciliation</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">Daily Sales Reconciliation: @LocationName</MudText>

    <MudTable Items="ReconcileList" Dense="true" Hover="true" Class="mt-4">
        <HeaderContent>
            <MudTh>Product</MudTh>
            <MudTh>System Predicted Sales</MudTh>
            <MudTh>Actual Sales (Manual Count)</MudTh>
            <MudTh>Discrepancy</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.ProductName</MudTd>
            <MudTd>@context.SystemSalesCount</MudTd>
            <MudTd>
                <MudNumericField @bind-Value="context.ActualSalesCount" Min="0" Variant="Variant.Outlined" Margin="Margin.Dense" Style="width: 120px;" />
            </MudTd>
            <MudTd>
                @{
                    var diff = context.ActualSalesCount - context.SystemSalesCount;
                    if (diff != 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Error">@diff</MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">-</MudText>
                    }
                }
            </MudTd>
        </RowTemplate>
    </MudTable>

    <MudPaper Elevation="1" Class="mt-6 pa-4">
        <MudStack Direction="Row" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <div>
                <MudText Typo="Typo.h6">Total Expected Revenue</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Based on your manual count of items sold today.</MudText>
            </div>
            <MudText Typo="Typo.h4" Color="Color.Success">@TotalRevenue.ToString("C")</MudText>
        </MudStack>
    </MudPaper>

    <MudStack Row="true" Class="mt-6" Spacing="2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveReconciliation">
            Finalize Nightly Sales
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Href="/inventory/stock">
            Cancel
        </MudButton>
    </MudStack>
</MudContainer>

@code {
    [Parameter] public int LocationId { get; set; }
    private string LocationName = "";
    private List<SaleReconcileItem> ReconcileList = new();

    protected override async Task OnInitializedAsync()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var location = await context.Locations.FindAsync(LocationId);
        if (location == null)
        {
            Navigation.NavigateTo("/inventory/stock");
            return;
        }
        LocationName = location.Name;

        var startOfToday = DateTime.UtcNow.Date;
        var salesToday = await context.Sales
            .Where(s => s.LocationId == LocationId && s.SaleDate >= startOfToday)
            .ToListAsync();

        var products = await context.Products.ToListAsync();

        ReconcileList = products.Select(p => new SaleReconcileItem
        {
            ProductId = p.Id,
            ProductName = p.Name,
            UnitPrice = p.Price,
            SystemSalesCount = salesToday.Where(s => s.ProductId == p.Id).Sum(s => s.QuantitySold),
            ActualSalesCount = salesToday.Where(s => s.ProductId == p.Id).Sum(s => s.QuantitySold)
        }).ToList();
    }

    private async Task SaveReconciliation()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        foreach (var item in ReconcileList)
        {
            var discrepancy = item.ActualSalesCount - item.SystemSalesCount;
            if (discrepancy != 0)
            {
                var stockRecord = await context.ProductLocations
                    .FirstOrDefaultAsync(pl => pl.LocationId == LocationId && pl.ProductId == item.ProductId);

                if (stockRecord != null)
                {
                    // Adjust stock based on manual count discrepancy
                    stockRecord.Quantity -= discrepancy;
                    stockRecord.LastUpdated = DateTime.UtcNow;

                    // Log the adjustment as a manual sale entry
                    context.Sales.Add(new Sale
                    {
                        ProductId = item.ProductId,
                        LocationId = LocationId,
                        QuantitySold = discrepancy,
                        UnitPriceAtSale = item.UnitPrice,
                        SaleDate = DateTime.UtcNow,
                        IsManualAdjustment = true
                    });
                }
            }
        }

        await context.SaveChangesAsync();
        Navigation.NavigateTo("/inventory/stock");
    }

    private decimal TotalRevenue => ReconcileList.Sum(item => item.ActualSalesCount * item.UnitPrice);

    public class SaleReconcileItem
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = "";
        public decimal UnitPrice { get; set; }
        public int SystemSalesCount { get; set; }
        public int ActualSalesCount { get; set; }
    }
}
