@inherits LayoutComponentBase

<MudLayout>
    <MudAppBar Elevation="4">
        <MudText Typo="Typo.h6">PuppetFestAPP.Web</MudText>
        <MudSpacer />
    </MudAppBar>

    <MudDrawer Anchor="Anchor.Left" Open="true" Elevation="1" ClipMode="DrawerClipMode.Always">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
