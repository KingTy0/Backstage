@page "/alerts"
@using Microsoft.EntityFrameworkCore
@using PuppetFestAPP.Web.Data
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Alerts</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudText Class="my-5"><h1>Alerts</h1></MudText>
    <MudText Color="Color.Secondary" Class="mb-4">
        <p class="body-1">Alerts for merchandise that are running low or out of stock will appear here.</p>
    </MudText>

    <MudDivider></MudDivider>

    <MudAlert Severity="Severity.Info" Class="mb-4">
        <MudText>
            <p class="body-2">Low stock is defined as less than <b>@InventoryAlerts.LowStockThreshold</b> units. Critical stock is less than or equal to <b>@InventoryAlerts.CriticalStockThreshold</b> units.</p>
        </MudText>
    </MudAlert>

    <MudGrid GutterSize="3">
        <MudItem xs="12">
            <MudPaper Elevation="1" Class="pa-4 h-100">
                <MudStack Direction="Row" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                    <MudText><h3>Location Alerts</h3></MudText>
                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">
                        @LocationGroups.Count low items
                    </MudChip>
                </MudStack>

                @if (LocationGroups.Any())
                {
                    <MudStack Spacing="3">
                        @foreach (var group in LocationGroups)
                        {
                            <MudCard Elevation="1">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        @if (InventoryAlerts.IsCriticalStock(group.Variants.Sum(v => v.Quantity)))
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Report" Color="Color.Error" Size="Size.Small" />
                                        } else {
                                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                                        }
                                        <MudText Typo="Typo.subtitle1" Style="font-weight:600">@group.ProductName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@group.LocationName</MudText>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        @if (InventoryAlerts.IsCriticalStock(group.Variants.Sum(v => v.Quantity)))
                                        {
                                            <MudChip T="string" Color="Color.Error" Variant="Variant.Outlined" Size="Size.Small">Critical</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Low</MudChip>
                                        }
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent Class="pt-0">
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                        @foreach (var variant in group.Variants)
                                        {
                                            <MudChip T="string"
                                                     Color="@(InventoryAlerts.IsCriticalStock(variant.Quantity) ? Color.Error : Color.Warning)"
                                                     Variant="Variant.Filled"
                                                     Size="Size.Small">
                                                @(variant.SizeLabel != null ? $"Size {variant.SizeLabel}: " : "")@(variant.Quantity == 0 ? "Out of stock" : $"{variant.Quantity} remaining")
                                            </MudChip>
                                        }
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        }
                    </MudStack>
                }
                else
                {
                    <MudAlert Severity="Severity.Success">No low stock items detected at any location.</MudAlert>
                }
            </MudPaper>
        </MudItem>

        @*
        <MudItem xs="12" md="6">
            <MudPaper Elevation="1" Class="pa-4 h-100">
                <MudStack Direction="Row" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                    <MudText><h3>Overall Stock Alerts</h3></MudText>
                    <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
                        @LowStockByProduct.Count products
                    </MudChip>
                </MudStack>

                @if (LowStockByProduct.Any())
                {
                    <MudStack Spacing="3">
                        @foreach (var item in LowStockByProduct)
                        {
                            <MudCard Elevation="1">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        @if (InventoryAlerts.IsCriticalStock(item.TotalQuantity))
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Report" Color="Color.Error" Size="Size.Small" />
                                        } else {
                                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                                        }
                                        <MudText Typo="Typo.subtitle1" Style="font-weight:600">@item.DisplayName</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@item.LocationCount location(s)</MudText>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        @if (InventoryAlerts.IsCriticalStock(item.TotalQuantity))
                                        {
                                            <MudChip T="string" Color="Color.Error" Variant="Variant.Outlined" Size="Size.Small">Critical</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Size="Size.Small">Low</MudChip>
                                        }
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent Class="pt-0">
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                        <MudChip T="string"
